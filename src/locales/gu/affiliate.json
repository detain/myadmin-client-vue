    "faqPage": {
        "title": "FAQ",
        "q1": "1. \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0a95\u0aae\u0abf\u0ab6\u0aa8 \u0ab0\u0a9a\u0aa8\u0abe \u0ab6\u0ac1\u0a82 \u0a9b\u0ac7?",
        "a1": "\u0a85\u0aae\u0ac7 \u0aaa\u0acd\u0ab0\u0aa4\u0abf \u0ab5\u0ac7\u0a9a\u0abe\u0aa3 $100 \u0aab\u0acd\u0ab2\u0ac5\u0a9f \u0a95\u0aae\u0abf\u0ab6\u0aa8 \u0a9a\u0ac2\u0a95\u0ab5\u0ac0\u0a8f \u0a9b\u0ac0\u0a8f, \u0a85\u0aa8\u0ac7 \u0a86 \u0ab8\u0acd\u0ab0\u0ac7\u0ab7\u0acd\u0aa0 \u0a9a\u0ac2\u0a95\u0ab5\u0aa3\u0ac0 \u0a95\u0ab0\u0aa4\u0abe \u0a8f\u0aab\u0abf\u0ab2\u0abf\u0a8f\u0a9f \u0aaa\u0acd\u0ab0\u0acb\u0a97\u0acd\u0ab0\u0abe\u0aae\u0acb\u0aae\u0abe\u0a82\u0aa8\u0acb \u0a8f\u0a95 \u0a9b\u0ac7.",
        "q2": "2. \u0a95\u0acb\u0a88 \u0ab5\u0ac7\u0a9a\u0abe\u0aa3 \u0aae\u0abe\u0ab0\u0abe \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f\u0aae\u0abe\u0a82 \u0aa6\u0ac7\u0a96\u0abe\u0ab5\u0abe\u0aae\u0abe\u0a82 \u0a95\u0ac7\u0a9f\u0ab2\u0acb \u0ab8\u0aae\u0aaf \u0ab2\u0abe\u0a97\u0ac7 \u0a9b\u0ac7?",
        "a2": "\u0a86 \u0aa4\u0ab0\u0aa4 \u0a9c \u0aa6\u0ac7\u0a96\u0abe\u0ab5\u0ac1\u0a82 \u0a9c\u0acb\u0a88\u0a8f.",
        "q3": "3. \u0aae\u0ac7\u0a82 \u0a39\u0þ \u0ab5\u0ac7\u0a9a\u0abe\u0aa3 \u0a95\u0ab0\u0acd\u0aaf\u0ac1\u0a82. \u0a39\u0ac1\u0a82 \u0a95\u0acd\u0aaf\u0abe\u0a82 \u0a9c\u0acb\u0a88 \u0ab6\u0a95\u0ac1\u0a82?",
        "a3_step1": "interserver.net \u0aaa\u0ab0 \u0ab2\u0cbe\u0a97 \u0a87\u0aa8 \u0a95\u0ab0\u0acb.",
        "a3_step2": "\u0aa8\u0ac0\u0a9a\u0ab2\u0abe \u0aa6\u0a95\u0acd\u0ab7\u0abf\u0aa3 \u0aac\u0abe\u0a9c\u0ac1\u0a8f \u0aa4\u0aae\u0aa8\u0ac7 View Affiliate Page \u0aa8\u0acb \u0ab5\u0abf\u0a95\u0ab2\u0acd\u0aaa \u0aa6\u0ac7\u0a96\u0abe\u0ab6\u0ac7.",
        "a3_step3": "\u0a85\u0ab9\u0ac0\u0a82 \u0aa4\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0aac\u0aa7\u0abe \u0aac\u0abe\u0a95\u0ac0 \u0a85\u0aa8\u0ac7 \u0aae\u0a82\u0a9c\u0ac2\u0ab0 \u0a95\u0aae\u0abf\u0ab6\u0aa8 \u0a9c\u0acb\u0a88 \u0ab6\u0a95\u0acb \u0a9b\u0acb.",
        "q4": "4. \u0aae\u0aa8\u0ac7 \u0a8f\u0ab5\u0abe \u0a95\u0acb\u0a88\u0aa8\u0ac0 \u0a9c\u0ab0\u0ac2\u0ab0 \u0a9b\u0ac7 \u0a9c\u0ac7\u0aa8\u0ac7 \u0ab9\u0acb\u0ab8\u0acd\u0a9f\u0abf\u0a82\u0a97 \u0a9c\u0acb\u0a88\u0a8f. \u0a39\u0ac1\u0a82 \u0ab0\u0ac7\u0aab\u0ab0\u0ab2 \u0aab\u0ac0 \u0a95\u0ac7\u0ab5\u0ac0 \u0ab0\u0ac0\u0aa4\u0ac7 \u0a95\u0aae\u0abe\u0ab5\u0ac1\u0a82?",
        "a4_step1": "interserver.net \u0aaa\u0ab0 \u0ab2\u0cbe\u0a97 \u0a87\u0aa8 \u0a95\u0ab0\u0acb.",
        "a4_step2": "\u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0a8f\u0aab\u0abf\u0ab2\u0abf\u0a8f\u0a9f \u0ab2\u0abf\u0a82\u0a95 \u0a9c\u0acb\u0ab5\u0abe \u0aa8\u0ac0\u0a9a\u0ac7 \u0ab8\u0acd\u0a95\u0cbe\u0aae\u0ac1 \u0a95\u0ab0\u0acb.",
        "a4_step3": "\u0aa4\u0aae\u0abe\u0ab0\u0abe \u0a8f\u0ab5\u0abe \u0a93\u0ab3\u0a96\u0abe\u0aa3\u0aa8\u0ac7 \u0a86 \u0ab2\u0abf\u0a82\u0a95 \u0aae\u0acb\u0a95\u0ab2\u0acb \u0a9c\u0ac7\u0aa8\u0ac7 \u0ab9\u0acb\u0ab8\u0acd\u0a9f\u0abf\u0a82\u0a97 \u0a9c\u0acb\u0a88\u0a8f.",
        "a4_step4": "\u0a9c\u0acd\u0aaf\u0abe\u0ab0\u0ac7 \u0aa4\u0ac7\u0a93 \u0a86 \u0ab2\u0abf\u0a82\u0a95 \u0a95\u0acd\u0ab2\u0abf\u0a95 \u0a95\u0ab0\u0ac7 \u0a85\u0aa8\u0ac7 \u0a85\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0aa5\u0ac7 \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0a86\u0ab0\u0acd\u0aa1\u0ab0 \u0a95\u0ab0\u0ac7, \u0aa4\u0aae\u0ac7 \u0a95\u0aae\u0abf\u0ab6\u0aa8 \u0a95\u0aae\u0abe\u0a93 \u0a9b\u0acb.",
        "q5": "5. \u0aae\u0aa8\u0ac7 InterServer \u0ab9\u0acb\u0ab8\u0acd\u0a9f\u0abf\u0a82\u0a97 \u0a8f\u0aab\u0abf\u0ab2\u0abf\u0a8f\u0a9f \u0aaa\u0acd\u0ab0\u0acb\u0a97\u0acd\u0ab0\u0abe\u0aae \u0aae\u0abe\u0a9f\u0ac7 \u0aae\u0a82\u0a9c\u0ac2\u0ab0\u0ac0 \u0aae\u0ab3\u0ac0 \u0a9b\u0ac7. \u0ab9\u0ab5\u0ac7 \u0ab6\u0ac1\u0a82 \u0a95\u0ab0\u0ac1\u0a82?",
        "a5_step1": "Banners and Links \u0a9f\u0ac7\u0aac \u0a95\u0acd\u0ab2\u0abf\u0a95 \u0a95\u0ab0\u0ac0\u0aa8\u0ac7 InterServer \u0aae\u0abe\u0ab0\u0a95\u0ac7\u0a9f\u0abf\u0a82\u0a97 \u0ab8\u0abe\u0aae\u0a97\u0acd\u0ab0\u0ac0 \u0a8a\u0aaa\u0ab2\u0aac\u0acd\u0aa7 \u0a95\u0ab0\u0ab5\u0abe \u0aa4\u0aae\u0abe\u0ab0\u0abe \u0a8f\u0aab\u0abf\u0ab2\u0abf\u0a8f\u0a9f \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f\u0aae\u0abe\u0a82 \u0ab2\u0cbe\u0a97 \u0a87\u0aa8 \u0a95\u0ab0\u0acb.",
        "a5_step2": "\u0aa4\u0aae\u0ac7 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0aaa\u0ab0 \u0a89\u0aae\u0ac7\u0ab0\u0ab5\u0abe \u0aae\u0abe\u0a82\u0a97\u0aa4\u0ac0 \u0aae\u0abe\u0ab0\u0a95\u0ac7\u0a9f\u0abf\u0a82\u0a97 \u0ab8\u0abe\u0aae\u0a97\u0acd\u0ab0\u0ac0 \u0aaa\u0ab8\u0a82\u0aa6 \u0a95\u0ab0\u0acb.",
        "a5_step3": "\u0aa4\u0aae\u0ac7 \u0aac\u0aa7\u0abe \u0aac\u0ac5\u0aa8\u0ab0\u0acd\u0ab8\u0aa8\u0ac0 \u0aa6\u0a95\u0acd\u0ab7\u0abf\u0aa3 \u0aac\u0abe\u0a9c\u0ac1\u0a8f \u0aac\u0ac5\u0aa8\u0ab0 \u0a95\u0acb\u0aa1 \u0a9c\u0acb\u0a88 \u0ab6\u0a95\u0ab6\u0acb; \u0a86 \u0a95\u0acb\u0aa1 \u0a95\u0cbe\u0aaa\u0ac0 \u0a95\u0ab0\u0ac0 \u0aa4\u0aae\u0abe\u0ab0\u0ac0 \u0ab8\u0abe\u0a87\u0a9f \u0aaa\u0ab0 \u0aaa\u0ac7\u0ab8\u0acd\u0a9f \u0a95\u0ab0\u0acb.",
        "a5_step4": "\u0a9c\u0acd\u0aaf\u0abe\u0ab0\u0ac7 \u0a95\u0acb\u0a88 \u0a86 \u0ab2\u0abf\u0a82\u0a95 \u0a95\u0acd\u0ab2\u0abf\u0a95 \u0a95\u0ab0\u0ac7 \u0a85\u0aa8\u0ac7 \u0ab9\u0acb\u0ab8\u0acd\u0a9f\u0abf\u0a82\u0a97 \u0a8f\u0a95\u0abe\u0a89\u0aa8\u0acd\u0a9f \u0a96\u0ab0\u0ac0\u0aa6\u0ac7, \u0aa4\u0aae\u0ac7 \u0a95\u0aae\u0abf\u0ab6\u0aa8 \u0a95\u0aae\u0abe\u0a93 \u0a9b\u0acb.",
        "q6": "6. \u0ab6\u0ac1\u0a82 \u0aae\u0ac7\u0a82 InterServer \u0ab9\u0acb\u0ab8\u0acd\u0a9f\u0abf\u0a82\u0a97 \u0aaa\u0acd\u0ab0\u0acb\u0aae\u0acb\u0a9f \u0a95\u0ab0\u0ab5\u0abe PPC \u0aac\u0cbf\u0aa1 \u0a95\u0ab0\u0ac0 \u0ab6\u0a95\u0ac1\u0a82?",
        "a6_line1": "\u0ab9\u0abe, \u0aaa\u0ab0\u0a82\u0aa4\u0ac1 \u0a85\u0aae\u0abe\u0ab0\u0abe \u0a95\u0cbe\u0ab0\u0aaa\u0acb\u0ab0\u0ac7\u0a9f \u0aa8\u0abe\u0aae, \u0a95\u0cbe\u0ab0\u0aaa\u0acb\u0ab0\u0ac7\u0a9f \u0aa8\u0abe\u0aae\u0aa8\u0ac0 \u0aad\u0abf\u0aa8\u0acd\u0aa8\u0aa4\u0abe, \u0a97\u0ab2\u0aa4 \u0aac\u0aa6\u0ab2\u0ac0 \u0a85\u0aa5\u0ab5\u0abe InterServer, InterServer Hosting \u0ab8\u0ab9\u0abf\u0aa4\u0aa8\u0acb \u0a95\u0acb\u0a88 \u0aad\u0abe\u0a97 \u0aae\u0abe\u0a82\u0aa8\u0ac0 \u0a95\u0acb\u0a88 \u0a95\u0ac0\u0ab5\u0ab0\u0acd\u0aa1 \u0aaa\u0ab0 \u0aac\u0cbf\u0aa1 \u0aa8 \u0a95\u0ab0\u0acb.",
        "a6_line2": "fast hosting, PHP hosting, WordPress hosting \u0a9c\u0ac7\u0ab5\u0ac0 \u0a95\u0ac0\u0ab5\u0ab0\u0acd\u0aa1\u0acd\u0ab8 \u0aaa\u0ab0 \u0aac\u0cbf\u0aa1 \u0aaa\u0ab0 \u0aa7\u0cbe\u0aaf\u0abe\u0aa8 \u0a86\u0aaa\u0acb.",
