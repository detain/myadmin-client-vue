    "faqPage": {
        "title": "\u0935\u093e\u0930\u0902\u0935\u093e\u0930 \u0935\u093f\u091a\u093e\u0930\u0932\u0947 \u091c\u093e\u0923\u093e\u0930\u0947 \u092a\u094d\u0930\u0936\u094d\u0928",
        "q1": "1. \u0924\u0941\u092e\u091a\u0940 \u0915\u092e\u093f\u0936\u0928 \u0930\u091a\u0928\u093e \u0915\u093e\u092f \u0906\u0939\u0947?",
        "a1": "\u0906\u092e\u094d\u0939\u0940 \u092a\u094d\u0930\u0924\u093f \u0935\u093f\u0915\u094d\u0930\u0940 $100 \u0938\u092e\u093e\u0928 \u0915\u092e\u093f\u0936\u0928 \u0926\u0947\u0924\u094b, \u0939\u093e \u0938\u0930\u094d\u0935\u093e\u0924 \u091c\u093e\u0938\u094d\u0924 \u092a\u0948\u0938\u0947 \u0926\u0947\u0923\u093e\u0930\u093e \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u092a\u094d\u0930\u094b\u0917\u094d\u0930\u093e\u092e\u093e\u0902\u092a\u0948\u0915\u0940 \u090f\u0915 \u0906\u0939\u0947.",
        "q2": "2. \u0935\u093f\u0915\u094d\u0930\u0940 \u092e\u093e\u091d\u094d\u092f\u093e \u0916\u093e\u0924\u094d\u092f\u093e\u0924 \u0926\u093f\u0938\u0923\u094d\u092f\u093e\u0938 \u0915\u093f\u0924\u0940 \u0935\u0947\u0933 \u0932\u093e\u0917\u0924\u094b?",
        "a2": "\u0924\u0947 \u0932\u0917\u0947\u091a \u0926\u093f\u0938\u0932\u0947 \u092a\u093e\u0939\u093f\u091c\u0947.",
        "q3": "3. \u092e\u0940 \u0928\u0941\u0915\u0924\u0940\u091a \u0935\u093f\u0915\u094d\u0930\u0940 \u0915\u0947\u0932\u0940. \u092e\u0940 \u0924\u0940 \u0915\u0941\u0920\u0947 \u092a\u093e\u0939\u0942 \u0936\u0915\u0924\u094b?",
        "a3_step1": "interserver.net \u0935\u0930 \u0932\u0949\u0917 \u0907\u0928 \u0915\u0930\u093e.",
        "a3_step2": "\u0916\u093e\u0932\u0940\u0932 \u0909\u091c\u0935\u094d\u092f\u093e \u092c\u093e\u091c\u0942\u0932\u093e \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u092a\u0947\u091c \u092a\u0939\u093e \u092a\u0930\u094d\u092f\u093e\u092f \u0926\u093f\u0938\u0947\u0932.",
        "a3_step3": "\u0907\u0925\u0947 \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0938\u0930\u094d\u0935 \u092a\u094d\u0930\u0932\u0902\u092c\u093f\u0924 \u0906\u0923\u093f \u092e\u0902\u091c\u0942\u0930 \u0915\u092e\u093f\u0936\u0928 \u0926\u093f\u0938\u0924\u093e\u0924.",
        "q4": "4. \u092e\u0932\u093e \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917\u0926\u0940\u0930 \u0915\u094b\u0923\u0940 \u0924\u0930\u0940 \u0928\u0935\u0940\u0928 \u0935\u094d\u092f\u0915\u094d\u0924\u0940 \u092e\u093e\u0939\u093f\u0924 \u0906\u0939\u0947. \u092e\u0940 \u0930\u0947\u092b\u0930\u0932 \u092b\u0940 \u0915\u0936\u0940 \u0915\u092e\u0935\u0942?",
        "a4_step1": "interserver.net \u0935\u0930 \u0932\u0949\u0917 \u0907\u0928 \u0915\u0930\u093e.",
        "a4_step2": "\u0924\u0941\u092e\u091a\u0940 \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u0932\u093f\u0902\u0915 \u092a\u093e\u0939\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0916\u093e\u0932\u0940 \u0938\u094d\u0915\u094d\u0930\u094b\u0932 \u0915\u0930\u093e.",
        "a4_step3": "\u0939\u0940 \u0932\u093f\u0902\u0915 \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917 \u0939\u0935\u0940 \u0905\u0938\u0932\u0947\u0932\u094d\u092f\u093e \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0913\u0933\u0916\u0940\u091a\u094d\u092f\u093e\u0932\u093e \u092a\u093e\u0920\u0935\u093e.",
        "a4_step4": "\u091c\u0947\u0935\u094d\u0939\u093e \u0924\u0947 \u0924\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u0935\u0930 \u0915\u094d\u0932\u093f\u0915 \u0915\u0930\u0924\u093e\u0924 \u0906\u0923\u093f \u0906\u092e\u091a\u094d\u092f\u093e\u0915\u0921\u0947 \u0916\u093e\u0924\u0947 \u0920\u0947\u0935\u0924\u093e\u0924, \u0924\u0947\u0935\u094d\u0939\u093e \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0915\u092e\u093f\u0936\u0928 \u092e\u093f\u0933\u0924\u0947.",
        "q5": "5. \u092e\u0932\u093e InterServer \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917 \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u092a\u094d\u0930\u094b\u0917\u094d\u0930\u093e\u092e\u0938\u093e\u0920\u0940 \u092e\u0902\u091c\u0942\u0930\u0940 \u092e\u093f\u0933\u093e\u0932\u0940. \u0906\u0924\u093e \u092e\u0940 \u0915\u093e\u092f \u0915\u0930\u0942?",
        "a5_step1": "\u092c\u0945\u0928\u0930 \u0906\u0923\u093f \u0932\u093f\u0902\u0915 \u091f\u0945\u092c\u0935\u0930 \u0915\u094d\u0932\u093f\u0915 \u0915\u0930\u0942\u0928 InterServer \u092e\u093e\u0930\u094d\u0915\u0947\u091f\u093f\u0902\u0917 \u0938\u093e\u0939\u093f\u0924\u094d\u092f \u0905\u0915\u094d\u0938\u0947\u0938 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u0916\u093e\u0924\u094d\u092f\u093e\u0935\u0930 \u0932\u0949\u0917 \u0907\u0928 \u0915\u0930\u093e.",
        "a5_step2": "\u0924\u0941\u092e\u094d\u0939\u0940 \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0938\u093e\u0907\u091f\u0935\u0930 \u091c\u094b\u0921\u093e\u092f\u091a\u0947 \u092e\u093e\u0930\u094d\u0915\u0947\u091f\u093f\u0902\u0917 \u0938\u093e\u0939\u093f\u0924\u094d\u092f \u0928\u093f\u0935\u0921\u093e.",
        "a5_step3": "\u0938\u0930\u094d\u0935 \u092c\u0945\u0928\u0930\u091a\u094d\u092f\u093e \u0909\u091c\u0935\u094d\u092f\u093e \u092c\u093e\u091c\u0942\u0932\u093e \u092c\u0945\u0928\u0930 \u0915\u094b\u0921 \u0926\u093f\u0938\u0924\u093e\u0924; \u0924\u094b \u0915\u094b\u0921 \u0915\u0949\u092a\u0940 \u0915\u0930\u0942\u0928 \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0938\u093e\u0907\u091f\u0935\u0930 \u092a\u0947\u0938\u094d\u091f \u0915\u0930\u093e.",
        "a5_step4": "\u091c\u0947\u0935\u094d\u0939\u093e \u0915\u094b\u0923\u0940 \u0924\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u0935\u0930 \u0915\u094d\u0932\u093f\u0915 \u0915\u0930\u0924\u0947 \u0906\u0923\u093f \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917 \u0916\u093e\u0924\u0947 \u0916\u0930\u0947\u0926\u0940 \u0915\u0930\u0924\u0947, \u0924\u0947\u0935\u094d\u0939\u093e \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0915\u092e\u093f\u0936\u0928 \u092e\u093f\u0933\u0924\u0947.",
        "q6": "6. \u092e\u0940 InterServer \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917 \u0932\u094b\u0915\u092a\u094d\u0930\u093f\u092f \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 PPC \u092c\u093f\u0921 \u0915\u0930\u0942 \u0936\u0915\u0924\u094b \u0915\u093e?",
        "a6_line1": "\u0939\u094b\u092f, \u092a\u0930\u0902\u0924\u0941 \u0915\u0943\u092a\u092f\u093e \u0906\u092e\u091a\u094d\u092f\u093e \u0915\u0949\u0930\u094d\u092a\u094b\u0930\u0947\u091f \u0928\u093e\u0935\u093e\u0935\u0930, \u0928\u093e\u0935\u093e\u091a\u094d\u092f\u093e \u092d\u093f\u0928\u094d\u0928\u0924\u093e\u0935\u0930, \u091a\u0941\u0915\u0940\u091a\u094d\u092f\u093e \u0936\u0941\u0926\u094d\u0927\u0932\u0947\u0916\u0928\u093e\u0935\u0930 \u0915\u093f\u0902\u0935\u093e InterServer \u0905\u0902\u0924\u0930\u094d\u092d\u0942\u0924 \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u0915\u0940\u0935\u0930\u094d\u0921\u0935\u0930 \u092c\u093f\u0921 \u0915\u0930\u0942 \u0928\u0915\u093e.",
        "a6_line2": "\u0935\u0947\u0917\u0935\u093e\u0928 \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917, PHP \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917, WordPress \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917 \u092f\u093e\u0902\u0938\u093e\u0930\u0916\u094d\u092f\u093e \u0915\u0940\u0935\u0930\u094d\u0921\u094d\u0938\u0935\u0930 \u092c\u093f\u0921 \u0915\u0930\u093e.",
        "a6_line3": "\u0915\u0940\u0935\u0930\u094d\u0921 \u0935\u093f\u091a\u093e\u0930 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u092e\u0926\u0924 \u0939\u0935\u0940 \u0905\u0938\u0932\u094d\u092f\u093e\u0938 \u0915\u0943\u092a\u092f\u093e \u0906\u092e\u091a\u094d\u092f\u093e\u0936\u0940 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u093e.",
        "a6_line4": "InterServer, InterServer Hosting, InterServer.net, InterServer web hosting \u0928\u0915\u093e\u0930\u093e\u0924\u094d\u092e\u0915 \u0915\u0945\u092e\u094d\u092a\u0947\u0928 \u0915\u0940\u0935\u0930\u094d\u0921 \u092e\u094d\u0939\u0923\u0942\u0928 \u091c\u094b\u0921\u0923\u0947 \u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0915\u0930\u093e.",
        "q7": "7. \u092e\u093e\u091d\u0940 \u0935\u093f\u0915\u094d\u0930\u0940 \u091d\u093e\u0932\u0940. \u0906\u0924\u093e \u092e\u0932\u093e \u092a\u0948\u0938\u0947 \u0915\u0947\u0935\u094d\u0939\u093e \u092e\u093f\u0933\u0924\u093e\u0924?",
        "a7_line1": "90 \u0926\u093f\u0935\u0938\u093e\u0902\u0928\u0902\u0924\u0930 \u0935\u0948\u0927 \u0935\u093f\u0915\u094d\u0930\u0940 \u0921\u093f\u092b\u0949\u0932\u094d\u091f \u0935\u0930\u0942\u0928 \u092a\u094d\u0930\u0932\u0902\u092c\u093f\u0924 \u0935\u0930 \u092c\u0926\u0932\u0947\u0932.",
        "a7_line2": "\u0935\u093f\u0915\u094d\u0930\u0940 \u092a\u094d\u0930\u0932\u0902\u092c\u093f\u0924 \u0905\u0938\u0932\u094d\u092f\u093e\u0928\u0902\u0924\u0930 \u092e\u0939\u093f\u0928\u094d\u092f\u093e\u091a\u094d\u092f\u093e \u092a\u0939\u093f\u0932\u094d\u092f\u093e 7 \u0926\u093f\u0935\u0938\u093e\u0902\u0924 \u092a\u0948\u0938\u0947 \u092e\u093f\u0933\u0924\u093e\u0924.",
        "q8": "8. \u092e\u093e\u091d\u0940 \u092a\u094d\u0930\u0932\u0902\u092c\u093f\u0924 \u0935\u093f\u0915\u094d\u0930\u0940 \u0906\u0939\u0947 \u0917\u0947\u0932\u094d\u092f\u093e\u0935\u0930 \u092a\u0948\u0938\u0947 \u092e\u093f\u0933\u093e\u0932\u0947 \u0928\u093e\u0939\u0940\u0924.",
        "a8_line1": "\u092f\u093e\u0938\u093e\u0920\u0940 \u0915\u093e\u0939\u0940 \u0915\u093e\u0930\u0923\u0947 \u0905\u0938\u0942 \u0936\u0915\u0924\u093e\u0924. \u0915\u0927\u0940\u0915\u0927\u0940 \u0935\u093f\u0915\u094d\u0930\u0940 \u092a\u094d\u0930\u092e\u093e\u0923\u093f\u0924 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0906\u092e\u094d\u0939\u093e\u0932\u093e \u0905\u0927\u093f\u0915 \u0935\u0947\u0933 \u0932\u093e\u0917\u0924\u094b.",
        "a8_line2": "\u0924\u092a\u093e\u0938\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0938\u0939\u091c \u0917\u094b\u0937\u094d\u091f \u092e\u094d\u0939\u0923\u091c\u0947 \u0924\u0941\u092e\u091a\u0940 \u092a\u0948\u092e\u0947\u0902\u091f \u092a\u0926\u094d\u0927\u0924 \u0938\u0947\u091f \u0915\u0947\u0932\u0940 \u0906\u0939\u0947 \u0915\u093e \u0939\u0947 \u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u0915\u0930\u093e.",
        "q9": "9. \u092e\u093e\u091d\u094d\u092f\u093e \u0935\u093f\u0915\u094d\u0930\u0940/\u0915\u092e\u093f\u0936\u0928 \u092e\u0902\u091c\u0942\u0930 \u0939\u094b\u0923\u094d\u092f\u093e\u092a\u0942\u0930\u094d\u0935\u0940 \u0915\u093f\u0924\u0940 \u0926\u093f\u0935\u0938 \u092a\u094d\u0930\u0932\u0902\u092c\u093f\u0924 \u0930\u093e\u0939\u0924\u0947?",
        "a9": "90 \u0926\u093f\u0935\u0938.",
        "q10": "10. \u092e\u0940 \u0935\u0948\u092f\u0915\u094d\u0924\u093f\u0915 \u0935\u093e\u092a\u0930\u093e\u0938\u093e\u0920\u0940 \u0916\u093e\u0924\u094d\u092f\u093e\u0902\u0935\u0930 \u0938\u094d\u0935\u0924:\u0936\u093f\u092b\u093e\u0930\u0938\u0940\u0938\u093e\u0920\u0940 \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u0932\u093f\u0902\u0915 \u0935\u093e\u092a\u0930\u0942 \u0936\u0915\u0924\u094b \u0915\u093e?",
        "a10": "\u0928\u093e\u0939\u0940. \u092a\u0941\u0928\u0930\u094d\u0935\u093f\u0915\u094d\u0930\u0940 \u0915\u0947\u0932\u0947\u0932\u094d\u092f\u093e \u0916\u093e\u0924\u094d\u092f\u093e\u0936\u0940 \u0915\u094b\u0923\u0924\u093e\u0939\u0940 \u0938\u0902\u092a\u0930\u094d\u0915 \u0935\u093f\u0915\u094d\u0930\u0940\u091a\u0947 \u0906\u092a\u094b\u0906\u092a \u0905\u092f\u0936 \u0915\u0930\u0947\u0932.",
        "q11": "11. \u092e\u093e\u091d\u0947 \u0915\u092e\u093f\u0936\u0928 \u0915\u093e \u0928\u093e\u0915\u093e\u0930\u0932\u0947?",
        "a11_intro": "\u0928\u093e\u0915\u093e\u0930\u0932\u0947\u0932\u0947 \u092e\u094d\u0939\u0923\u091c\u0947 \u0915\u092e\u093f\u0936\u0928 \u0915\u093e\u092f\u092e\u091a\u0947 \u0905\u092f\u0936\u0938\u094d\u0935\u0940 \u0920\u0930\u0932\u0947.",
        "a11_reasons": "\u092f\u093e\u091a\u0940 \u0915\u093e\u0939\u0940 \u0915\u093e\u0930\u0923\u0947:",
        "a11_reason1": "\u0917\u094d\u0930\u093e\u0939\u0915\u093e\u0928\u0947 \u092a\u0942\u0930\u094d\u0935\u0940 \u0906\u092e\u091a\u094d\u092f\u093e\u0915\u0921\u0947 \u0928\u094b\u0902\u0926\u0923\u0940 \u0915\u0947\u0932\u0940 \u0906\u0939\u0947.",
        "a11_reason2": "\u0938\u092e\u093e\u0928 \u092a\u0948\u092e\u0947\u0902\u091f \u092a\u0926\u094d\u0927\u0924 \u0926\u0941\u0938\u0930\u094d\u092f\u093e \u0916\u093e\u0924\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0935\u093e\u092a\u0930\u0932\u0940 \u0939\u094b\u0924\u0940.",
        "a11_reason3": "\u092a\u094d\u0930\u0923\u093e\u0932\u0940\u0928\u0947 \u0936\u094b\u0927\u0932\u0947 \u0915\u0940 \u0924\u0941\u092e\u094d\u0939\u0940 \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u0917\u094d\u0930\u093e\u0939\u0915\u093e\u091a\u0947 \u0916\u093e\u0924\u0947 \u0926\u0947\u0916\u0940\u0932 \u0935\u093e\u092a\u0930\u0924 \u0906\u0939\u093e\u0924.",
        "a11_policy": "\u092a\u094d\u0930\u0924\u093f \u0935\u093f\u0915\u094d\u0930\u0940\u0938\u093e\u0920\u0940 \u0906\u092e\u091a\u0947 $100 \u092a\u0947\u0906\u0909\u091f \u0917\u094d\u0930\u093e\u0939\u0915\u093e\u0915\u0921\u0942\u0928  1 \u0935\u0930\u094d\u0937\u093e\u0928\u0902\u0924\u0930\u0939\u0940 \u0906\u092e\u094d\u0939\u0940 \u0935\u0938\u0942\u0932 \u0915\u0930\u0924\u094b \u0924\u094d\u092f\u093e\u092a\u0947\u0915\u094d\u0937\u093e \u091c\u093e\u0938\u094d\u0924 \u0905\u0938\u0924\u094b, \u0906\u092e\u091a\u094d\u092f\u093e\u0915\u0921\u0947 \u0906\u092e\u091a\u094d\u092f\u093e \u092e\u093e\u0930\u094d\u0917\u0926\u0930\u094d\u0936\u0915 \u0924\u0924\u094d\u0935\u093e\u0902\u0928\u0941\u0938\u093e\u0930 \u0928\u0938\u0932\u0947\u0932\u094d\u092f\u093e \u0936\u093f\u092b\u093e\u0930\u0936\u0940 \u0936\u094b\u0927\u0923\u094d\u092f\u093e\u091a\u0940 \u0915\u0920\u094b\u0930 \u0928\u0940\u0924\u0940 \u0906\u0939\u0947.",
        "a11_reviewTos": "\u0915\u0943\u092a\u092f\u093e \u0906\u092e\u091a\u094d\u092f\u093e \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u0905\u091f\u0940\u0936\u0930\u094d\u0924\u0940 \u0907\u0925\u0947 \u092a\u0939\u093e:",
        "q12": "12. \u092e\u0940 \u0921\u093f\u091c\u093e\u092f\u0928\u0930/\u0921\u0947\u0935\u094d\u0939\u0932\u092a\u0930 \u0906\u0939\u0947 \u0906\u0923\u093f \u0917\u094d\u0930\u093e\u0939\u0915\u093e\u0902\u0928\u093e \u0936\u093f\u092b\u093e\u0930\u0938 \u0915\u0930\u0947\u0928. \u0924\u0947 \u0920\u0940\u0915 \u0906\u0939\u0947 \u0915\u093e?",
        "a12_line1": "\u0939\u0940 \u092f\u094b\u091c\u0928\u093e \u0906\u092e\u091a\u094d\u092f\u093e\u0936\u0940 \u0915\u093e\u092e \u0915\u0930\u0923\u093e\u0930 \u0928\u093e\u0939\u0940. \u0905\u0928\u0947\u0915 \u0916\u093e\u0924\u094d\u092f\u093e\u0902\u0935\u0930 \u091c\u0941\u0933\u0923\u093e\u0930\u094d\u092f\u093e \u0935\u0947\u0933\u0940 \u0915\u092e\u093f\u0936\u0928 \u0905\u092f\u0936\u0938\u094d\u0935\u0940 \u0939\u094b\u0924\u0947.",
        "a12_line2": "\u0939\u0947 \u0938\u094d\u0935\u0924: \u0928\u094b\u0902\u0926\u0923\u0940 \u0915\u0930\u0942\u0928 \u0905\u092b\u093f\u0932\u093f\u090f\u091f \u092a\u094d\u0930\u094b\u0917\u094d\u0930\u093e\u092e\u0935\u0930 \u092a\u0948\u0938\u0947 \u0915\u092e\u0935\u0923\u0947 \u0930\u094b\u0916\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0915\u0947\u0932\u0947 \u0906\u0939\u0947.",
        "a12_line3": "\u0924\u0941\u092e\u094d\u0939\u0940 PayPal \u0938\u093e\u0930\u0916\u094d\u092f\u093e \u0938\u0947\u0935\u0947\u091a\u093e \u0935\u093e\u092a\u0930 \u0915\u0930\u0942\u0928 \u0917\u094d\u0930\u093e\u0939\u0915\u093e\u0902\u0928\u093e \u0925\u0947\u091f \u0939\u094b\u0938\u094d\u091f \u0915\u0930\u0923\u094d\u092f\u093e\u091a\u093e \u0935\u093f\u091a\u093e\u0930 \u0915\u0930\u0942 \u0936\u0915\u0924\u093e. \u0906\u092e\u091a\u094d\u092f\u093e\u0915\u0921\u0942\u0928 \u0930\u093f\u0938\u0947\u0932\u0930 \u0939\u094b\u0938\u094d\u091f\u093f\u0902\u0917 \u0916\u093e\u0924\u0947 \u0916\u0930\u0947\u0926\u0940 \u0915\u0930\u093e.",
