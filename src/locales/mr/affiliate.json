        "viewLandingPage": "\u0932\u0945\u0902\u0921\u093f\u0902\u0917 \u092a\u0947\u091c \u092a\u0939\u093e",
        "couponName": "\u0915\u0942\u092a\u0928 \u0928\u093e\u0935",
        "couponTooltip": "\u091c\u0947\u0935\u094d\u0939\u093e \u0928\u0935\u0940\u0928 \u0915\u094d\u0932\u093e\u092f\u0902\u091f \u0939\u0947 \u0915\u0942\u092a\u0928 \u0935\u093e\u092a\u0930\u0924\u094b, \u0924\u0947\u0935\u094d\u0939\u093e \u0924\u094d\u092f\u093e\u0902\u0928\u093e \u0924\u0941\u092e\u091a\u094d\u092f\u093e\u0926\u094d\u0935\u093e\u0930\u0947 \u0936\u093f\u092b\u093e\u0930\u0938 \u0915\u0947\u0932\u0947\u0932\u0947 \u092e\u094d\u0939\u0923\u0942\u0928 \u091f\u0945\u0917 \u0915\u0947\u0932\u0947 \u091c\u093e\u0908\u0932.",
